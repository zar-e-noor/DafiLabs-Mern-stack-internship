datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?  
  message   String
  status    String   @default("Pending") 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contacts")
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique // Supabase Auth User ID ke liye
  email     String   @unique
  name      String?
  role      String   @default("Admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}